{
  "name": "multi-agent-orchestrator",
  "version": "1.0.0",
  "description": "A Node.js-based multi-agent collaborative platform for software development pipeline",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "build:server": "tsc",
    "build:web": "vite build",
    "start": "NODE_ENV=production node dist/index.js",
    "dev": "concurrently -n api,web,tunnel -c blue,green,magenta \"tsx src/index.ts\" \"tsx scripts/wait-then-vite.ts\" \"E:\\tools\\cloudflared\\cloudflared.exe tunnel --url http://localhost:3000 --metrics 127.0.0.1:20241\"",
    "dev:api": "tsx src/index.ts",
    "dev:web": "vite",
    "test": "vitest --run"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@lancedb/lancedb": "^0.27.2",
    "@types/ws": "^8.18.1",
    "cheerio": "^1.2.0",
    "express": "^5.2.1",
    "jszip": "^3.10.1",
    "multer": "^2.1.1",
    "officeparser": "^6.1.0",
    "openai": "^6.34.0",
    "qrcode": "^1.5.4",
    "uuid": "^14.0.0",
    "word-extractor": "^1.0.4",
    "ws": "^8.20.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^10.0.0",
    "@types/xml2js": "^0.4.14",
    "concurrently": "^9.2.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.4"
  }
}
